# Copy this file to .env and fill in your real values. Never commit .env itself.

# MongoDB connection string.
# Local: mongodb://127.0.0.1:27017/chand-sewing
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chand-sewing
MONGO_URI=mongodb://127.0.0.1:27017/chand-sewing

# Any long random string — used to sign login tokens.
JWT_SECRET=replace_this_with_a_long_random_string

# How long a login session (JWT) stays valid.
JWT_EXPIRES_IN=7d

# Port the API server runs on.
PORT=5000

# Your React app's URL, so the browser is allowed to call this API (CORS).
CLIENT_URL=http://localhost:3000
